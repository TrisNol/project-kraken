# APP settings
ENVIRONMENT=production # Defaults to 'development' if not set. Can be 'development' or 'production'.

# Local/remote LLM host (used for Ollama). Example: http://localhost:11434
LLM_HOST=http://mockhost.local:7869/

# Which provider to use for chat generation: 'ollama', 'openai', or 'azure'
# When set to 'openai' the server uses OpenAI components and requires OPENAI_API_KEY.
# When set to 'azure' the server uses Azure OpenAI-backed components and requires
# AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_API_KEY.
LLM_CHAT_PROVIDER=ollama
# Which provider to use for embeddings: 'ollama', 'openai', or 'azure'
# Defaults to the value of LLM_CHAT_PROVIDER when not set.
LLM_EMBEDDING_PROVIDER=ollama

# Model names for chat and embeddings
# For Azure, these values should be your deployment names.
LLM_CHAT_MODEL=mock-model
LLM_EMBEDDING_MODEL=mock-embed-model

# OpenAI API key (only required when using OpenAI as a provider)
OPENAI_API_KEY=sk-I've-tried-so-hard-and-got-so-far-but-in-the-end-it-doesn't-even-matter

# Azure OpenAI settings (required when using Azure as a provider)
# Endpoint example: https://<resource-name>.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://mock-resource.openai.azure.com
AZURE_OPENAI_API_KEY=mock-azure-openai-api-key
# Azure chat deployment name (used by Azure chat provider).
# If unset, LLM_CHAT_MODEL is used.
AZURE_DEPLOYMENT_NAME=mock-chat-deployment
# API version example: 2024-10-21
AZURE_OPENAI_API_VERSION=2024-10-21

EMBEDDING_DIMENSION=768

CONFLUENCE_URL=https://mock.atlassian.net/wiki
CONFLUENCE_USERNAME=mock.user@example.com
CONFLUENCE_API_KEY=mock-api-key
CONFLUENCE_SPACES=MOCK_SPACE

JIRA_URL=https://mock.atlassian.net
JIRA_USERNAME=mock.user@example.com
JIRA_API_KEY=mock-api-key
JIRA_PROJECTS=MOCK_PROJECT

GITHUB_REPOSITORIES=https://github.com/mockuser/mock-repo1.git,https://github.com/mockuser/mock-repo2.git
GITHUB_REF=mock-branch

NEO4J_URL=bolt://mockhost.local:7687
NEO4J_USERNAME=mock_user
NEO4J_PASSWORD=mock_password
